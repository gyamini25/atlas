# ─── Atlas backend configuration ─────────────────────────────────────────────
# Copy to `.env` and adjust. Every value has a sensible default for local dev.

# ── LLM / reasoning ──────────────────────────────────────────────────────────
# The reasoning engine runs on GPT-5.6. Supply your OpenAI key to run live.
OPENAI_API_KEY=
# Chat model used by the reasoning pipeline. Override if the id differs.
ATLAS_MODEL=gpt-5.6
# Fallback models tried if ATLAS_MODEL is unavailable to your key (comma-separated),
# so a mis-typed / unreleased id degrades gracefully instead of failing the demo.
ATLAS_MODEL_FALLBACKS=gpt-5,gpt-4.1,gpt-4o
# Embedding model for the evidence retriever.
ATLAS_EMBEDDING_MODEL=text-embedding-3-large
# live  → call OpenAI for reasoning + embeddings
# mock  → replay recorded traces from backend/seed (no network, deterministic demo)
ATLAS_LLM_MODE=mock

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres + pgvector. Matches docker-compose.yml defaults.
ATLAS_DATABASE_URL=postgresql+psycopg://atlas:atlas@localhost:5432/atlas

# ── Graph store ──────────────────────────────────────────────────────────────
# networkx → in-process graph (default, zero external deps)
# neo4j    → use the Neo4j instance (start with `docker compose --profile neo4j up`)
ATLAS_GRAPH_BACKEND=networkx
ATLAS_NEO4J_URI=bolt://localhost:7687
ATLAS_NEO4J_USER=neo4j
ATLAS_NEO4J_PASSWORD=atlaspassword

# ── Optional integrations ────────────────────────────────────────────────────
# GitHub token to enrich the graph with PRs/issues (public repos work unauthenticated,
# but a token raises rate limits and unlocks private repos).
ATLAS_GITHUB_TOKEN=

# ── Server ───────────────────────────────────────────────────────────────────
ATLAS_HOST=127.0.0.1
ATLAS_PORT=8787
ATLAS_LOG_LEVEL=info
