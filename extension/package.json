{
  "name": "atlas-vscode",
  "displayName": "Atlas — Engineering Memory",
  "description": "Ask why code exists. Atlas reconstructs engineering intent from your repository's history.",
  "version": "0.1.0",
  "publisher": "atlas",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Machine Learning"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atlas",
          "title": "Atlas",
          "icon": "media/atlas-icon.svg"
        }
      ]
    },
    "views": {
      "atlas": [
        {
          "id": "atlas.panel",
          "name": "Atlas",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "atlas.ask",
        "title": "Ask Atlas: Why does this exist?",
        "category": "Atlas"
      },
      {
        "command": "atlas.replay",
        "title": "Atlas: Replay Evolution",
        "category": "Atlas"
      },
      {
        "command": "atlas.impact",
        "title": "Atlas: Impact Analysis",
        "category": "Atlas"
      },
      {
        "command": "atlas.indexRepository",
        "title": "Atlas: Index Repository",
        "category": "Atlas"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "atlas.ask",
          "when": "editorHasSelection",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "atlas.ask",
        "key": "cmd+k cmd+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Atlas",
      "properties": {
        "atlas.backendUrl": {
          "type": "string",
          "default": "https://atlas-backend-ryj4.onrender.com",
          "description": "URL of the Atlas backend API. Defaults to the hosted demo backend, which has the sample repository pre-indexed. Point it at http://127.0.0.1:8787 to use a backend you run locally via ./run.sh."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "vite build",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --external:vscode --format=cjs --outfile=dist/extension.js",
    "build": "npm run build:webview && npm run build:extension",
    "watch": "npm run build:extension -- --watch",
    "package": "npm run build && npx --yes @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.20.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.0"
  }
}
